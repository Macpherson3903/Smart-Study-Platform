# Clerk – https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# MongoDB Atlas – https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=smart-study          # optional, defaults to "smart-study"

# Google Gemini – https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-3.1-flash-lite-preview   # optional

# AI generation quotas (per-user, MongoDB-backed). Defaults shown.
# GENERATE_BURST_LIMIT=5                # max generations per burst window
# GENERATE_BURST_WINDOW_SECONDS=60      # burst window length
# GENERATE_DAILY_LIMIT=30               # max generations per UTC day

# Public site URL (used for canonical metadata, OG, sitemap, robots).
# NEXT_PUBLIC_APP_URL=https://smartstudy.example.com
